        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-5m", "to": "now" },
  "title": "SWIM Gossip Protocol",
  "uid": "swim-gossip-overview"
}
